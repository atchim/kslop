# docker — kernel symbols required by Docker for cgroups v2,
# namespaces, overlayfs, and bridge networking.
#
# Draft — first build not yet attempted. Populate the Verified section
# after the first successful merge+build.

# Namespaces
# ----------
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_USER_NS=y
CONFIG_NET_NS=y

# Cgroups
# -------
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_CPUSETS=y

# Storage
# -------
CONFIG_OVERLAY_FS=y

# Networking
# ----------
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_VETH=y
CONFIG_NF_NAT=y

# vim: ft=conf
