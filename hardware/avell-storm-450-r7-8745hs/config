# avell-storm-450-r7-8745hs — AMD Ryzen 7 8745HS + NVIDIA RTX 4050
# Mobile laptop on a Clevo NH-series barebones.
#
# Verified:
#   liquorix-sources 7.0.9_p1 (2026-05-23)

# CPU & Platform
# --------------
CONFIG_X86_AMD_PSTATE=y
CONFIG_X86_AMD_PSTATE_DEFAULT_MODE=3
CONFIG_AMD_PMC=y
# AMD_PMF needs the TEE stack + sensor-fusion-hub for full operation.
CONFIG_TEE=m
CONFIG_AMDTEE=m
CONFIG_AMD_SFH_HID=m
CONFIG_AMD_PMF=m
CONFIG_AMD_IOMMU=y
# CONFIG_MICROCODE=y only enables the loader; with no initramfs
# (ADR-0003) it has no source to load from, so the CPU stays on BIOS
# microcode and AMD errata/security mitigations (e.g. Transient
# Scheduler Attacks) go unfixed. Embed the Zen 4 (family 0x19) blob
# into the image so it loads at the earliest boot stage without an
# initramfs. Bump the filename if a future CPU is a different family.
CONFIG_MICROCODE=y
CONFIG_EXTRA_FIRMWARE="amd-ucode/microcode_amd_fam19h.bin"
CONFIG_EXTRA_FIRMWARE_DIR="/lib/firmware"
CONFIG_SENSORS_K10TEMP=m
CONFIG_I2C_PIIX4=m
CONFIG_SP5100_TCO=m
CONFIG_CRYPTO_DEV_CCP=y
CONFIG_CRYPTO_DEV_CCP_DD=m

# Storage
# -------
# Built-in (=y): root lives on NVMe; the kernel must see it without
# help from an initramfs (see ADR-0003).
CONFIG_BLK_DEV_NVME=y

# Graphics
# --------
CONFIG_DRM_AMDGPU=m
# Ada Lovelace is unusable under nouveau; the proprietary
# nvidia-drivers package owns the dGPU stack.
# CONFIG_DRM_NOUVEAU is not set

# Audio
# -----
CONFIG_SND_HDA_INTEL=m
# Codec drivers — without these, snd_hda_intel binds the PCI controller
# but no driver knows how to talk to the codec, and probing fails with
# "Cannot probe codecs, giving up".
CONFIG_SND_HDA_GENERIC=m
CONFIG_SND_HDA_CODEC_REALTEK=m
CONFIG_SND_HDA_CODEC_HDMI=m
# SOF stack for AMD ACP 6.3 (internal mic / speakers). TOPLEVEL is the
# menuconfig gate that wraps the whole sound/soc/sof/Kconfig subtree.
CONFIG_SND_SOC=m
CONFIG_SND_SOC_SOF_TOPLEVEL=y
CONFIG_SND_SOC_SOF_PCI=m
CONFIG_SND_SOC_SOF_AMD_TOPLEVEL=m
CONFIG_SND_SOC_SOF_AMD_ACP63=m

# Networking
# ----------
CONFIG_R8169=m
CONFIG_IWLWIFI=m
CONFIG_IWLMVM=m

# Bluetooth
# ---------
# Intel AX210 BT is wired over USB (8087:0032), so the USB HCI transport
# is the relevant binding. BT_HCIBTUSB selects BT_INTEL automatically.
CONFIG_BT=m
CONFIG_BT_HCIBTUSB=m

# Media
# -----
# Chicony USB UVC webcam (04f2:b729) needs the V4L2 stack via the USB
# media bus. MEDIA_SUPPORT_FILTER is on by default; the *_SUPPORT knobs
# are how categories get opted in past the filter.
CONFIG_MEDIA_SUPPORT=m
CONFIG_MEDIA_USB_SUPPORT=y
CONFIG_MEDIA_CAMERA_SUPPORT=y
CONFIG_USB_VIDEO_CLASS=m

# USB
# ---
CONFIG_USB_XHCI_PCI=m

# Input — touchpad
# ----------------
# Integrated touchpad is an Elan I2C-HID (ELAN0415 in ACPI) wired to
# a Synopsys DesignWare I2C controller (AMDI0010 in ACPI), with its
# interrupt line routed through an AMD pin-controller GPIO. Chain:
#   COMMON_CLK            — clock framework I2C_DESIGNWARE_PLATFORM
#                           depends on (kernel framework, hence =y)
#   PINCTRL + PINCTRL_AMD — AMD GPIO/pin controller. Without it the
#                           ACPI-described touchpad interrupt cannot
#                           be translated to a Linux IRQ, and
#                           i2c_hid_acpi probe fails with -EINVAL.
#   I2C_DESIGNWARE_*      — exposes the AMDI0010 controller as i2c bus
#   I2C_HID_ACPI          — HID-over-I2C transport
#   HID_MULTITOUCH        — gesture-aware HID class driver
# AMDPSP variant covers the AMD PSP-integrated I2C path used by some
# Phoenix chipsets. AMD_MP2 is for the sensor-fusion hub I2C, not the
# touchpad, but stays in for AMD_SFH_HID's benefit.
CONFIG_COMMON_CLK=y
CONFIG_PINCTRL=y
CONFIG_PINCTRL_AMD=y
CONFIG_I2C_DESIGNWARE_CORE=m
CONFIG_I2C_DESIGNWARE_PLATFORM=m
CONFIG_I2C_DESIGNWARE_PCI=m
CONFIG_I2C_DESIGNWARE_AMDPSP=y
CONFIG_I2C_AMD_MP2=m
CONFIG_I2C_HID_ACPI=m
CONFIG_HID_MULTITOUCH=m

# vim: ft=conf
