# efi-boot — UEFI boot environment. GRUB, installed as an EFI
# application, is the bootloader; these symbols give the kernel UEFI
# firmware services, EFI System Partition recognition, and efivars.
# EFI_STUB is retained so the image stays directly EFI-bootable as a
# fallback, but GRUB is the actual loader.
#
# Verified:
#   liquorix-sources 7.0.9_p1 (2026-05-23)

CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_MIXED=y
CONFIG_EFI_PARTITION=y
CONFIG_EFIVAR_FS=y
# DRM_SIMPLEDRM drives the firmware-supplied framebuffer until amdgpu
# (or another GPU driver) takes over — cleaner than the legacy FB_EFI
# path, which would also require CONFIG_FB=y.
CONFIG_DRM_SIMPLEDRM=y

# vim: ft=conf
